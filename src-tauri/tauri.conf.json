{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Decision Notepad",
  "version": "0.1.0",
  "identifier": "app.decisionnotepad",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "bash scripts/setup-dist.sh",
    "beforeDevCommand": "bash scripts/setup-dist.sh"
  },
  "app": {
    "windows": [
      {
        "title": "Decision Notepad",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
