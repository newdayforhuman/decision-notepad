{
  "$schema": "design-tokens",
  "name": "decision-notepad",
  "version": "0.1.0",

  "color": {
    "surface": {
      "page":     { "value": "oklch(98.2% 0.008 80)" },
      "raised":   { "value": "oklch(99.4% 0.005 80)" },
      "sunken":   { "value": "oklch(96.0% 0.010 80)" },
      "selected": { "value": "oklch(94.2% 0.014 80)" }
    },
    "ink": {
      "strong":  { "value": "oklch(22% 0.012 60)" },
      "body":    { "value": "oklch(32% 0.010 60)" },
      "muted":   { "value": "oklch(52% 0.008 60)" },
      "faint":   { "value": "oklch(68% 0.006 60)" },
      "inverse": { "value": "oklch(98% 0.005 80)" }
    },
    "text": {
      "meta":    { "value": "{color.ink.faint}", "comment": "Secondary reference info (timestamps, source meta). Use rather than ink.muted when content is purely reference." }
    },
    "rule": {
      "hairline": { "value": "oklch(90% 0.008 80)" },
      "strong":   { "value": "oklch(82% 0.010 80)" },
      "focus":    { "value": "oklch(55% 0.14 250)" }
    },
    "marker": {
      "greenFill":   { "value": "#d9e6cf" },
      "greenText":   { "value": "#2f4d28" },
      "orangeFill":  { "value": "#efcdb8" },
      "orangeText":  { "value": "#6a2a10" },
      "yellowFill":  { "value": "#ead496" },
      "yellowText":  { "value": "#5a4309" },
      "blueFill":    { "value": "#c5dcef" },
      "blueText":    { "value": "#0e3e6b" },
      "purpleFill":  { "value": "#cfc8e6" },
      "purpleText":  { "value": "#2c225e" },
      "tealFill":    { "value": "#a9cdb9" },
      "tealText":    { "value": "#0c3a2c" },
      "grayFill":    { "value": "#d4d2c6" },
      "grayText":    { "value": "#2d2c25" },
      "redFill":     { "value": "#e2a895" },
      "redText":     { "value": "#5a1808" },
      "keep":        { "value": "{color.marker.greenText}" },
      "reject":      { "value": "{color.marker.orangeText}" },
      "question":    { "value": "{color.marker.yellowText}" },
      "verify":      { "value": "{color.marker.blueText}" },
      "keepTint":    { "value": "{color.marker.greenFill}" },
      "rejectTint":  { "value": "{color.marker.orangeFill}" },
      "questionTint":{ "value": "{color.marker.yellowFill}" },
      "verifyTint":  { "value": "{color.marker.blueFill}" }
    },
    "accent": {
      "base":  { "value": "oklch(45% 0.14 265)" },
      "hover": { "value": "oklch(40% 0.16 265)" },
      "tint":  { "value": "oklch(94% 0.030 265)" },
      "on":    { "value": "oklch(98% 0.005 265)" }
    },
    "danger": {
      "base": { "value": "oklch(50% 0.16 28)" },
      "tint": { "value": "oklch(94% 0.030 28)" }
    }
  },

  "space": {
    "0":  { "value": "0px" },
    "1":  { "value": "4px" },
    "2":  { "value": "8px" },
    "3":  { "value": "12px" },
    "4":  { "value": "16px" },
    "5":  { "value": "20px" },
    "6":  { "value": "24px" },
    "8":  { "value": "32px" },
    "10": { "value": "40px" },
    "12": { "value": "48px" },
    "16": { "value": "64px" }
  },

  "font": {
    "ui":   { "value": "\"IBM Plex Sans\", system-ui, -apple-system, sans-serif" },
    "body": { "value": "\"IBM Plex Serif\", Charter, Georgia, serif" },
    "mono": { "value": "\"IBM Plex Mono\", ui-monospace, \"SF Mono\", Menlo, monospace" }
  },

  "fontSize": {
    "xs":   { "value": "11px" },
    "sm":   { "value": "13px" },
    "base": { "value": "14px" },
    "md":   { "value": "15px" },
    "lg":   { "value": "18px" },
    "xl":   { "value": "22px" }
  },

  "lineHeight": {
    "tight":   { "value": 1.25 },
    "snug":    { "value": 1.4 },
    "normal":  { "value": 1.55 },
    "relaxed": { "value": 1.7 }
  },

  "fontWeight": {
    "regular":  { "value": 400 },
    "medium":   { "value": 500 },
    "semibold": { "value": 600 }
  },

  "radius": {
    "xs":   { "value": "2px" },
    "sm":   { "value": "4px" },
    "md":   { "value": "6px" },
    "lg":   { "value": "10px" },
    "pill": { "value": "999px" }
  },

  "shadow": {
    "1":        { "value": "0 1px 0 0 oklch(0% 0 0 / 0.04)" },
    "2":        { "value": "0 2px 8px -2px oklch(0% 0 0 / 0.06), 0 1px 0 0 oklch(0% 0 0 / 0.04)" },
    "popover":  { "value": "0 8px 24px -8px oklch(0% 0 0 / 0.18), 0 0 0 1px oklch(0% 0 0 / 0.06)" }
  },

  "motion": {
    "duration": {
      "fast": { "value": "120ms" },
      "base": { "value": "180ms" },
      "slow": { "value": "260ms" }
    },
    "easing": {
      "standard": { "value": "cubic-bezier(0.2, 0.0, 0.0, 1.0)" },
      "emphasis": { "value": "cubic-bezier(0.3, 0.0, 0.0, 1.0)" }
    }
  },

  "layout": {
    "sidebarWidth":      { "value": "220px" },
    "detailWidth":       { "value": "360px" },
    "rowMinHeight":      { "value": "56px" },
    "rowPaddingY":       { "value": "12px" },
    "contentMaxWidth":   { "value": "980px" },
    "marginGlyphWidth":  { "value": "28px" }
  }
}
